  margin-left: 2px;
}
.twx-mx-2px {
  margin-left: 2px;
  margin-right: 2px;
}
.twx-max-h-250px {
  max-height: 250px;
}
.twx-max-h-220px {
  max-height: 220px;
}
.twx-max-h-200px {
  max-height: 200px;
}
.twx-py-30px {
  padding-top: 30px;
  padding-bottom: 30px;
}
.twx-border-1px {
  border-width: 1px;
}
.twx-shadow-dropdown {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}
.twx-shadow-focus {
  box-shadow: 0 0 0 2rpx rgba(24, 144, 255, 0.1);
}
.twx-border-light {
  border-color: #ebeef5;
}
.twx-border-base {
  border-color: #dcdfe6;
}
.twx-border-lighter {
  border-color: #f5f7fa;
}
.twx-bg-light {
  background-color: #fafafa;
}
.twx-bg-active {
  background-color: #ecf5ff;
}
.twx-bg-muted {
  background-color: #f9fafb;
}
.twx-bg-hover {
  background-color: #f5f7fa;
}
.twx-bg-disabled {
  background-color: #f5f5f5;
}
.twx-h-34px {
  height: 34px;
}
</style>
