<script  setup lang="uts" >
/**
 * Popup 弹出层组件
 * 支持 bottom、top、left、right、center 五种位置
 */
import { computed, nextTick, ref, watch } from 'vue'
import type { TPopupProps } from './type.uts'

const model = defineModel<boolean>({ default: false })
// 内部渲染状态，用于控制 DOM 显示
const rendered = ref(false)
// 是否显示遮罩层和内容
const showOverlay = ref(false)

const props = withDefaults(defineProps<TPopupProps>(), {
	height: '50%',
	width: '100%',
	position: 'bottom',
	showTitle: true,
	title: '',
	showClose: true,
	round: true,
	borderRadius: 32,
	closeOnClickOverlay: true,
	zIndex: 999,
	background: 'var(--tui-surface)'
})

/**
 * 事件
 */
const emit = defineEmits<{
	close : []
	open : []
}>()

// 计算弹窗高度
const popupHeight = computed(() : string => {
	if (typeof props.height === 'number') {
		return props.height + 'rpx'
	}
	return props.height
})

// 计算弹窗宽度
const popupWidth = computed(() : string => {
	if (typeof props.width === 'number') {
		return props.width + 'rpx'
	}
	return props.width
})

// 计算圆角大小
const popupBorderRadius = computed(() : string => {
	if (typeof props.borderRadius === 'number') {
		return props.borderRadius + 'rpx'
	}
	return props.borderRadius
})

// 计算弹窗样式
const popupStyle = computed(() : string => {
	const styles : string[] = []

	// 根据位置设置尺寸
	if (props.position === 'left' || props.position === 'right') {
		styles.push(`width: ${popupWidth.value}`)
		styles.push(`height: 100%`)
	} else if (props.position === 'center') {
		styles.push(`width: ${popupWidth.value}`)
		styles.push(`height: ${popupHeight.value}`)
	} else {
		styles.push(`height: ${popupHeight.value}`)
		styles.push(`width: 100%`)
	}

	styles.push(`z-index: ${props.zIndex}`)
	styles.push(`background-color: ${props.background}`)

	// 根据位置设置圆角
	if (props.round) {
		switch (props.position) {
			case 'bottom':
				styles.push(`border-top-left-radius: ${popupBorderRadius.value}`)
				styles.push(`border-top-right-radius: ${popupBorderRadius.value}`)
				break
			case 'top':
				styles.push(`border-bottom-left-radius: ${popupBorderRadius.value}`)
				styles.push(`border-bottom-right-radius: ${popupBorderRadius.value}`)
				break
			case 'left':
				styles.push(`border-top-right-radius: ${popupBorderRadius.value}`)
				styles.push(`border-bottom-right-radius: ${popupBorderRadius.value}`)
				break
			case 'right':
				styles.push(`border-top-left-radius: ${popupBorderRadius.value}`)
				styles.push(`border-bottom-left-radius: ${popupBorderRadius.value}`)
				break
			case 'center':
				styles.push(`border-radius: ${popupBorderRadius.value}`)
				break
		}
	}

	return styles.join('; ')
})

// 计算弹窗位移动画样式，避免依赖 Tailwind transform 变量在 uvue 中的兼容性
const popupMotionStyle = computed(() : string => {
	const styles : string[] = []

	switch (props.position) {
		case 'top':
			styles.push(`transform: ${showOverlay.value ? 'translateY(0)' : 'translateY(-100%)'}`)
			styles.push('transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)')
			break
		case 'left':
			styles.push(`transform: ${showOverlay.value ? 'translateX(0)' : 'translateX(-100%)'}`)
			styles.push('transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)')
			break
		case 'right':
			styles.push(`transform: ${showOverlay.value ? 'translateX(0)' : 'translateX(100%)'}`)
			styles.push('transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)')
			break
		case 'center':
			styles.push('transform: translate(-50%, -50%)')
			styles.push(`opacity: ${showOverlay.value ? '1' : '0'}`)
			styles.push('transition: opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)')
			break
		default:
			styles.push(`transform: ${showOverlay.value ? 'translateY(0)' : 'translateY(100%)'}`)
			styles.push('transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)')
			break
	}

	return styles.join('; ')
})

const contentStyle = computed(() : string => {
	const styles : string[] = []

	if (popupStyle.value != '') {
		styles.push(popupStyle.value)
	}

	if (popupMotionStyle.value != '') {
		styles.push(popupMotionStyle.value)
	}

	return styles.join('; ')
})

// 计算遮罩层样式
const overlayStyle = computed(() : string => {
	return `z-index: ${props.zIndex - 1}; transition: opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94)`
})

// 计算内容动画类名
const contentClass = computed(() => {
	const classes : string[] = ['fixed flex flex-col overflow-hidden bg-white']

	switch (props.position) {
		case 'top':
			classes.push('left-0 right-0 top-0')
			break
		case 'left':
			classes.push('bottom-0 left-0 top-0')
			break
		case 'right':
			classes.push('bottom-0 right-0 top-0')
			break
		case 'center':
			classes.push('left-1/2 top-1/2')
			break
		default:
			classes.push('bottom-0 left-0 right-0')
			break
	}

	return classes.join(' ')
})

// 计算容器样式类名
const wrapperClass = computed(() => {
	const classes : string[] = ['flex']

	switch (props.position) {
		case 'top':
			classes.push('items-start')
			break
		case 'left':
			classes.push('justify-start')
			break
		case 'right':
			classes.push('justify-end')
			break
		case 'center':
			classes.push('items-center justify-center')
			break
		default:
			classes.push('items-end')
			break
	}

	return classes.join(' ')
})

/**
 * 点击遮罩层
 */
const handleOverlayClick = () => {
	if (props.closeOnClickOverlay) {
		handleClose()
	}
}

/**
 * 阻止事件冒泡
 */
const stopPropagation = (e : any) => {
	// 阻止点击弹窗内容时触发遮罩层点击事件
}

/**
 * 禁止底部滚动
 */
const disableBodyScroll = () => {
	// H5 环境
	// #ifdef H5
	document.body.style.overflow = 'hidden'
	document.body.style.touchAction = 'none'
	// #endif

	// 小程序、App 端自动通过遮罩层阻止滚动
}

/**
 * 恢复底部滚动
 */
const enableBodyScroll = () => {
	// #ifdef H5
	document.body.style.overflow = ''
	document.body.style.touchAction = ''
	// #endif
}

/**
 * 关闭弹窗
 */
const handleClose = () => {
	// 隐藏遮罩层和内容，触发动画
	showOverlay.value = false

	// 等待关闭动画完成后再卸载 DOM
	setTimeout(() => {
		rendered.value = false
		enableBodyScroll()
		model.value = false  // 同步更新 model 状态
		emit('close')
	}, 350) // 稍长于动画时长，确保动画完整播放
}

watch(model, (newVal : boolean) => {
	if (newVal) {
		// 打开时立即渲染 DOM
		rendered.value = true
		// 初始状态为隐藏
		showOverlay.value = false
		// 下一帧显示遮罩层和内容，触发动画
		nextTick(() => {
			// 使用 setTimeout 确保 DOM 已渲染
			setTimeout(() => {
				showOverlay.value = true
				emit('open')
				disableBodyScroll()
			}, 10)
		})
	} else {
		// 外部关闭时触发关闭动画
		if (rendered.value) {
			handleClose()
		}
	}
})
</script>

<template>
  <view v-if="rendered" :class="wrapperClass">
    <!-- 遮罩层 -->
    <view
      class="fixed inset-0 overflow-hidden bg-black/50 touch-none select-none"
      :class="{ 'opacity-0': !showOverlay, 'opacity-100': showOverlay }"
      :style="overlayStyle"
      @click="handleOverlayClick"
    ></view>

    <!-- 弹窗主体 -->
    <view
      :class="contentClass"
      :style="contentStyle"
      @click="stopPropagation"
    >
      <!-- 标题栏 -->
      <view v-if="showTitle" class="relative flex h-[100rpx] shrink-0 items-center justify-center border-b border-[#dcdfe6] px-[32rpx]">
        <view class="flex flex-1 items-center justify-center">
          <slot name="title">
            <text class="text-[32rpx] font-semibold text-[#303133]">{{ title }}</text>
          </slot>
        </view>

        <!-- 关闭按钮 -->
        <view
          v-if="showClose"
          class="absolute right-[32rpx] flex h-[56rpx] w-[56rpx] items-center justify-center rounded-full transition-colors duration-300 active:bg-black/5"
          style="top: 50%; transform: translateY(-50%)"
          @click="handleClose"
        >
          <text class="text-[40rpx] leading-none text-[#909399]">✕</text>
        </view>
      </view>

      <!-- 内容区域 -->
      <view class="flex-1 overflow-y-auto p-[32rpx]">
        <slot></slot>
      </view>
    </view>
  </view>
</template>
