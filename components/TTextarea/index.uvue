<script setup lang="uts">
import { ref, computed } from 'vue'
import type { Ref } from 'vue'
import type { TTextareaProps } from './type.uts'

/**
 * TTextarea 多行文本输入组件
 * @description 支持自动高度、字数统计、清空等功能的多行文本输入框
 */

// Props 定义 (从 type.uts 导入，排除 modelValue)
type Props = Omit<TTextareaProps, 'modelValue'>

const props = withDefaults(defineProps<Props>(), {
  placeholder: '请输入内容',
  placeholderStyle: '',
  disabled: false,
  maxlength: -1,
  showCount: false,
  autoHeight: false,
  rows: 3,
  autoFocus: false,
  clearable: false,
  focusBorderColor: '#409eff',
  focusBackgroundColor: '',
  focusBoxShadow: '',
  customClass: '',
  customStyle: ''
})

// 使用 defineModel 管理双向绑定
const modelValue = defineModel({ default: '' }) as Ref<string>

// Emits 定义
const emit = defineEmits<{
  input: [value: string]
  focus: [event: object]
  blur: [event: object]
  clear: []
}>()

type TextareaInputEventDetail = {
  value: string
}
type TextareaInputEvent = {
  detail: TextareaInputEventDetail
}

// 状态管理
const isFocused = ref(false)

const hasTextValue = (value: string | null): boolean => {
  return value !== null && value !== ''
}

const showFooter = computed((): boolean => {
  return props.showCount || props.clearable
})

const canClear = computed((): boolean => {
  return props.clearable && modelValue.value.length > 0 && !props.disabled
})

/**
 * 计算当前字符数
 */
const currentLength = computed((): number => {
  return modelValue.value.length
})

/**
 * 计算容器类名
 */
const containerClasses = computed((): string => {
  const classes: string[] = [
    't-textarea relative rounded border border-border bg-white px-3 py-2 transition-colors duration-200',
  ]

  if (props.disabled) {
    classes.push('cursor-not-allowed border-border-soft bg-[#f5f7fa]')
  }

  if (hasTextValue(props.customClass)) {
    classes.push(props.customClass)
  }

  return classes.join(' ')
})

/**
 * 计算容器样式
 */
const containerStyle = computed((): string => {
  const styles: string[] = []

  if (isFocused.value) {
    if (hasTextValue(props.focusBorderColor)) {
      styles.push(`border-color: ${props.focusBorderColor}`)
    }
    if (hasTextValue(props.focusBackgroundColor)) {
      styles.push(`background-color: ${props.focusBackgroundColor}`)
    }
    if (hasTextValue(props.focusBoxShadow)) {
      styles.push(`box-shadow: ${props.focusBoxShadow}`)
    }
  }

  if (hasTextValue(props.customStyle)) {
    styles.push(props.customStyle)
  }

  return styles.join('; ')
})

/**
 * 计算 textarea 样式
 */
const textareaStyle = computed((): string => {
  const styles: string[] = []

  if (!props.autoHeight && props.rows > 0) {
    // 固定行数时计算高度（每行约 24px + 12px 行间距）
    const height = props.rows * 36
    styles.push(`height: ${height}px`)
  }

  return styles.join('; ')
})

/**
 * 输入事件处理
 */
const handleInput = (event: TextareaInputEvent): void => {
  const value = event.detail.value as string
  modelValue.value = value
  emit('input', value)
}

/**
 * 聚焦事件处理
 */
const handleFocus = (event: object): void => {
  isFocused.value = true
  emit('focus', event)
}

/**
 * 失焦事件处理
 */
const handleBlur = (event: object): void => {
  isFocused.value = false
  emit('blur', event)
}

/**
 * 清空输入
 */
const handleClear = (): void => {
  modelValue.value = ''
  emit('clear')
}
</script>

<template>
  <view :class="containerClasses" :style="containerStyle">
    <!-- 文本域 -->
    <textarea
      class="t-textarea__input w-full resize-none border-none bg-transparent text-sm leading-[1.5] text-primary outline-none box-border"
      :class="{ 'cursor-not-allowed text-disabled': disabled }"
      :style="textareaStyle"
      :value="modelValue"
      :placeholder="placeholder"
      :placeholder-style="placeholderStyle"
      :disabled="disabled"
      :maxlength="maxlength"
      :auto-height="autoHeight"
      :focus="autoFocus"
      @input="handleInput"
      @focus="handleFocus"
      @blur="handleBlur"
    />

    <!-- 底部操作栏 -->
    <view v-if="showFooter" class="t-textarea__footer mt-2 flex items-center justify-between border-t border-divider pt-2">
      <!-- 字数统计 -->
      <text v-if="showCount" class="t-textarea__count text-xs text-tertiary">
        {{ currentLength }}{{ maxlength > 0 ? `/${maxlength}` : '' }}
      </text>

      <!-- 清空按钮 -->
      <view
        v-if="canClear"
        class="t-textarea__clear flex h-5 w-5 items-center justify-center rounded-full bg-[#c0c4cc] transition-colors duration-200 active:bg-[#909399]"
        @click="handleClear"
      >
        <text class="t-textarea__clear-icon text-xs text-white">✕</text>
      </view>
    </view>
  </view>
</template>
