<script  setup lang="uts" >
import { ref } from 'vue'
import TRate from '@/components/TRate'
import TCard from '@/components/TCard'
import { useI18n } from '@/composables/useI18n.uts'

/**
 * 评分组件示例页面
 */

const { $t } = useI18n()

const value1 = ref(3)
const value2 = ref(2.5)
const value3 = ref(4)
const value4 = ref(0)

const handleChange = (value: number): void => {
  console.log('评分值:', value)
}
</script>

<template>
  <view class="example-page">
    <view class="example-header">
      <text class="example-title">{{ $t('examplePages.rate.title') }}</text>
      <text class="example-desc">{{ $t('examplePages.rate.description') }}</text>
    </view>

    <TCard :title="$t('examplePages.rate.sections.basic')" class="example-section">
      <TRate v-model="value1" />
      <text style="margin-top: 10px; font-size: 14px; color: #909399;">
        当前评分: {{ value1 }}
      </text>
    </TCard>

    <TCard :title="$t('examplePages.rate.sections.halfStar')" class="example-section">
      <TRate v-model="value2" allowHalf />
      <text style="margin-top: 10px; font-size: 14px; color: #909399;">
        支持半星评分: {{ value2 }}
      </text>
    </TCard>

    <TCard :title="$t('examplePages.rate.sections.readonly')" class="example-section">
      <view style="display: flex; flex-direction: column; gap: 10px;">
        <TRate :value="3.5" readonly allowHalf />
        <TRate :value="4" readonly />
        <TRate :value="2.3" readonly allowHalf />
      </view>
    </TCard>

    <TCard title="禁用" class="example-section">
      <TRate :value="3" disabled />
    </TCard>

    <TCard title="不同数量" class="example-section">
      <view style="display: flex; flex-direction: column; gap: 10px;">
        <view>
          <TRate :count="3" />
          <text style="font-size: 12px; color: #909399;">3颗星</text>
        </view>
        <view>
          <TRate :count="5" />
          <text style="font-size: 12px; color: #909399;">5颗星（默认）</text>
        </view>
        <view>
          <TRate :count="10" />
          <text style="font-size: 12px; color: #909399;">10颗星</text>
        </view>
      </view>
    </TCard>

    <TCard title="不同大小" class="example-section">
      <view style="display: flex; flex-direction: column; gap: 10px;">
        <TRate :size="30" />
        <TRate :size="40" />
        <TRate :size="50" />
      </view>
    </TCard>

    <TCard title="自定义颜色" class="example-section">
      <view style="display: flex; flex-direction: column; gap: 10px;">
        <TRate color="#f56c6c" />
        <TRate color="#67c23a" />
        <TRate color="#e6a23c" />
      </view>
    </TCard>

    <TCard title="自定义图标" class="example-section">
      <view style="display: flex; flex-direction: column; gap: 10px;">
        <TRate icon="♥" voidIcon="♡" />
        <TRate icon="👍" voidIcon="👍" />
      </view>
    </TCard>

    <TCard title="显示文字" class="example-section">
      <TRate v-model="value3" showText />
      <view style="margin-top: 15px;">
        <TRate v-model="value4" showText :texts="['极差', '失望', '一般', '满意', '惊喜']" />
      </view>
    </TCard>

    <TCard title="事件处理" class="example-section">
      <TRate @change="handleChange" />
      <text style="margin-top: 10px; font-size: 12px; color: #909399;">
        点击星星查看控制台
      </text>
    </TCard>
  </view>
</template>

