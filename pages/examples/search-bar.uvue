<script setup lang="uts">
import { ref } from 'vue'
import TSearchBar from '@/components/TSearchBar'
import TCard from '@/components/TCard'
import { useI18n } from '@/composables/useI18n.uts'

/**
 * TSearchBar 组件示例页面
 */

const { $t } = useI18n()

const value1 = ref('')
const value2 = ref('')
const value3 = ref('')

const handleSearch = (value: string): void => {
  console.log($t('examplePages.searchBar.messages.search'), value)
  uni.showToast({
    title: `${$t('examplePages.searchBar.messages.search')}: ${value}`,
    icon: 'none'
  })
}

const handleCancel = (): void => {
  console.log($t('examplePages.searchBar.messages.cancelled'))
  uni.showToast({
    title: $t('examplePages.searchBar.messages.cancelled'),
    icon: 'none'
  })
}
</script>

<template>
  <view class="demo-page">
    <!-- 基础用法 -->
    <TCard :title="$t('examplePages.searchBar.sections.basic')" padding="none">
      <TSearchBar v-model="value1" @search="handleSearch" />
    </TCard>

    <!-- 圆角样式 -->
    <TCard :title="$t('examplePages.searchBar.sections.round')" padding="none">
      <TSearchBar
        v-model="value2"
        shape="round"
        :placeholder="$t('examplePages.searchBar.placeholder.round')"
        @search="handleSearch"
      />
    </TCard>

    <!-- 显示取消按钮 -->
    <TCard :title="$t('examplePages.searchBar.sections.showCancel')" padding="none">
      <TSearchBar
        v-model="value3"
        :show-cancel="true"
        :cancel-text="$t('examplePages.searchBar.buttons.cancel')"
        @search="handleSearch"
        @cancel="handleCancel"
      />
    </TCard>

    <!-- 自定义背景色 -->
    <TCard :title="$t('examplePages.searchBar.sections.customBackground')" padding="none">
      <TSearchBar
        v-model="value1"
        background="#e6f7ff"
        :placeholder="$t('examplePages.searchBar.placeholder.background')"
      />
    </TCard>

    <!-- 禁用状态 -->
    <TCard :title="$t('examplePages.searchBar.sections.disabled')" padding="none">
      <TSearchBar
        v-model="value1"
        :disabled="true"
        :placeholder="$t('examplePages.searchBar.placeholder.disabled')"
      />
    </TCard>

    <!-- 自定义图标 -->
    <TCard :title="$t('examplePages.searchBar.sections.customIcon')" padding="none">
      <TSearchBar
        v-model="value1"
        left-icon="🔎"
        :placeholder="$t('examplePages.searchBar.placeholder.customIcon')"
      />
    </TCard>

    <!-- 限制长度 -->
    <TCard :title="$t('examplePages.searchBar.sections.maxlength')" padding="none">
      <TSearchBar
        v-model="value1"
        :maxlength="20"
        :placeholder="$t('examplePages.searchBar.placeholder.maxlength')"
      />
    </TCard>
  </view>
</template>

<style lang="scss" scoped>
.demo-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20px;
}
</style>
