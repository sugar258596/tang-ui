  padding: 20rpx;
  background-color: #fff;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;

  text {
    font-size: 28rpx;
    color: #606266;
  }
}

.tab-content-bottom {
  padding: 40rpx;
  background-color: #fff;
  min-height: 300rpx;

  .content-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #303133;
    display: block;
    margin-bottom: 20rpx;
  }

  .content-text {
    font-size: 28rpx;
    color: #909399;
    display: block;
  }
}

.current-value {
  display: block;
  margin-top: 20rpx;
