  margin-bottom: 20px;
}

.result-list {
  display: flex;
  flex-direction: column;
}

.result-title {
  display: block;
  font-size: 16px;
  font-weight: bold;
  color: #303133;
  line-height: 24px;
  margin-bottom: 10px;
}

.result-item {
  display: block;
  font-size: 14px;
  color: #303133;
  line-height: 22px;
  margin-bottom: 10px;
}

.result-raw {
  display: block;
  font-size: 12px;
  color: #606266;
  line-height: 20px;
}

.button-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 12px;
}

.button-item {
  margin-right: 10px;
  margin-bottom: 10px;
}
</style>
