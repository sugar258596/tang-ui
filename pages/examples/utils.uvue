  margin-bottom: 20px;
}

.result-list {
  display: flex;
  flex-direction: column;
}

.result-item {
  display: block;
  font-size: 14px;
  color: #303133;
  line-height: 22px;
  margin-bottom: 10px;
}

.result-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.result-flex {
  flex: 1;
  margin-bottom: 0;
}

